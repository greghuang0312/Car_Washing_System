<view class="container">
  <view wx:if="{{hasActiveOrder}}" class="card washing-card">
    <text class="section-title">洗车进行中</text>
    <view class="row">
      <text class="label">订单号</text>
      <text class="value">{{orderId}}</text>
    </view>
    <view class="row">
      <text class="label">站点</text>
      <text class="value">{{stationId}}</text>
    </view>
    <view class="row timer-row">
      <text class="label">已用时</text>
      <text class="timer">{{elapsedTime}}</text>
    </view>
    <button class="btn-danger" loading="{{loading}}" bindtap="onEndWash">结束洗车</button>
  </view>

  <view wx:if="{{!hasActiveOrder}}" class="card empty-card">
    <text class="empty-title">当前没有进行中的洗车订单</text>
    <text class="empty-hint">请返回首页重新扫码开始</text>
    <button class="btn-primary" bindtap="goHome">返回首页</button>
  </view>
</view>
