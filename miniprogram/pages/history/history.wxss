.empty-hint {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
}

.order-item {
  padding: 24rpx 30rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.order-station {
  font-weight: bold;
  font-size: 30rpx;
}

.status-washing {
  color: #1890ff;
}

.status-completed {
  color: #ff9800;
}

.status-paid {
  color: #52c41a;
}

.order-info {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 4rpx;
}
